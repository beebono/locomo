[submodule "external/ihslib"]
	path = external/ihslib
	url = https://github.com/beebono/ihslib.git
[submodule "external/SDL2"]
	path = external/SDL2
	url = https://github.com/libsdl-org/SDL.git
	branch = SDL2
[submodule "external/ffmpeg"]
	path = external/ffmpeg
	url = https://github.com/FFmpeg/FFmpeg.git
	branch = release/8.1
[submodule "external/SDL2_ttf"]
	path = external/SDL2_ttf
	url = https://github.com/libsdl-org/SDL_ttf.git
	branch = SDL2
[submodule "external/rkmpp"]
	path = external/rkmpp
	url = https://github.com/rockchip-linux/mpp.git
	branch = develop
[submodule "external/libudev-zero"]
	path = external/libudev-zero
	url = https://github.com/illiliti/libudev-zero.git
[submodule "external/protobuf-c"]
	path = external/protobuf-c
	url = https://github.com/protobuf-c/protobuf-c.git
[submodule "external/mbedtls"]
	path = external/mbedtls
	url = https://github.com/Mbed-TLS/mbedtls.git
	branch = archive/mbedtls-2.28
[submodule "external/libdrm"]
	path = external/libdrm
	url = https://gitlab.freedesktop.org/mesa/libdrm.git
